
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------//
    // Helper Functions
    //-------------------------------------------------------------------------//

    /**
     * isSignedIn
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * isOwner
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the foundation of the user-ownership security model.
     * @param userId The user ID to check against the authenticated user.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * isExistingOwner
     * Combines ownership check with a document existence check.
     * CRITICAL for all update and delete operations to prevent acting on
     * non-existent documents.
     * @param userId The user ID to check against the authenticated user.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * hasValidUserDataOnCreate
     * Validates that the user's internal 'id' field matches their UID upon creation.
     * This enforces relational integrity between the document ID and its content.
     * @param userId The user ID from the path.
     */
    function hasValidUserDataOnCreate(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * isUserDataImmutableOnUpdate
     * Ensures the internal 'id' field of a user document cannot be changed after creation.
     * This prevents tampering with the core ownership identifier.
     */
    function isUserDataImmutableOnUpdate() {
      return request.resource.data.id == resource.data.id;
    }
    
    /**
     * hasValidGangSheetDataOnCreate
     * Validates that the gangSheet's internal 'userId' field matches the owner's UID upon creation.
     * This enforces the ownership link between a user and their gang sheet.
     * @param userId The user ID from the path.
     */
    function hasValidGangSheetDataOnCreate(userId) {
      return request.resource.data.userId == userId;
    }

    /**
     * isGangSheetDataImmutableOnUpdate
     * Ensures the internal 'userId' field of a gangSheet document cannot be changed after creation.
     */
    function isGangSheetDataImmutableOnUpdate() {
      return request.resource.data.userId == resource.data.userId;
    }

    /**
     * hasValidOrderDataOnCreate
     * Validates that the order's internal 'userId' field matches the owner's UID upon creation.
     * This enforces the ownership link between a user and their order.
     * @param userId The user ID from the path.
     */
    function hasValidOrderDataOnCreate(userId) {
      return request.resource.data.userId == userId;
    }
    
    /**
     * isOrderDataImmutableOnUpdate
     * Ensures the internal 'userId' field of an order document cannot be changed after creation.
     */
    function isOrderDataImmutableOnUpdate() {
      return request.resource.data.userId == resource.data.userId;
    }
    
    /**
     * hasValidUserOrderDataOnCreate
     * Validates that the user-specific order's internal 'customerId' matches the owner's UID upon creation.
     */
    function hasValidUserOrderDataOnCreate(userId) {
      return request.resource.data.customerId == userId;
    }

    /**
     * isUserOrderDataImmutableOnUpdate
     * Ensures the internal 'customerId' field of a user-specific order document cannot be changed after creation.
     */
    function isUserOrderDataImmutableOnUpdate() {
      return request.resource.data.customerId == resource.data.customerId;
    }


    /**
     * isCreatingOwnOrder
     * Validates that the order's internal 'customerId' field matches the creator's UID.
     * This enforces the ownership link for the central orders collection.
     */
    function isCreatingOwnOrder() {
        return request.resource.data.customerId == request.auth.uid;
    }
    
    /**
     * isAdmin
     * Checks if the user is an admin by looking at custom claims OR a document in the roles_admin collection.
     */
    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.admin == true || exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    //-------------------------------------------------------------------------//
    // Collection: roles_admin
    //-------------------------------------------------------------------------//
    /**
     * @description Stores admin role flags. Only admins can read/write.
     * This collection is for internal role management.
     */
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }

    //-------------------------------------------------------------------------//
    // Collection: sheetSizes
    //-------------------------------------------------------------------------//
    /**
     * @description Stores global pricing information for sheet sizes. Publicly readable.
     * @path /sheetSizes/{sheetSizeId}
     * @allow Any user (including unauthenticated) to read pricing information.
     * @allow Any authenticated user to write to allow for initial setup.
     */
    match /sheetSizes/{sheetSizeId} {
      allow read, list: if true;
      allow write: if isSignedIn();
    }
    
    //-------------------------------------------------------------------------//
    // Collection: serviceAddOns
    //-------------------------------------------------------------------------//
    /**
     * @description Stores global service add-ons. Publicly readable.
     * @path /serviceAddOns/{addOnId}
     * @allow Any user (including unauthenticated) to read service add-ons.
     * @allow Any authenticated user to write to allow for initial setup.
     */
    match /serviceAddOns/{addOnId} {
        allow read, list: if true;
        allow write: if isSignedIn();
    }


    //-------------------------------------------------------------------------//
    // Collection: users
    //-------------------------------------------------------------------------//

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow A signed-in user (auth.uid='user123') creating their own profile document at `/users/user123`. (create)
     * @deny An anonymous user trying to read a user profile. (get)
     * @deny A user ('user123') trying to update another user's ('user456') profile. (update)
     * @principle Restricts access to a user's own data tree and allows self-creation of a profile.
     */
    match /users/{userId} {
      // Users can get their own document. Admins can read any user profile.
      allow get: if isOwner(userId) || isAdmin();
      
      // Only admins can list all users.
      allow list: if isAdmin();

      // A user can create their own profile document, establishing their presence.
      allow create: if isOwner(userId) && hasValidUserDataOnCreate(userId);

      // A user can update their own profile. Admins can update any profile.
      // Key relational fields are immutable.
      allow update: if (isExistingOwner(userId) || isAdmin()) && isUserDataImmutableOnUpdate();

      // Deleting user profiles is disabled by default for data integrity.
      allow delete: if false;

      //-----------------------------------------------------------------------//
      // Subcollection: gangSheets
      //-----------------------------------------------------------------------//

      /**
       * @description Controls access to a user's private gang sheets.
       * @path /users/{userId}/gangSheets/{gangSheetId}
       * @allow The owner ('user123') creating a new gang sheet in their own subcollection. (create)
       * @allow The owner ('user123') listing all of their own gang sheets. (list)
       * @deny A different user ('user456') attempting to read a gang sheet owned by 'user123'. (get)
       * @principle Enforces strict ownership for all operations within a user's private subcollection.
       */
      match /gangSheets/{gangSheetId} {
        // Owner can read their own gang sheets and list their collection.
        allow get, list: if isOwner(userId);
        
        // Owner can create new gang sheets, linking them via the internal userId field.
        allow create: if isOwner(userId) && hasValidGangSheetDataOnCreate(userId);
        
        // Owner can update an existing gang sheet. The ownership link is immutable.
        allow update: if isExistingOwner(userId) && isGangSheetDataImmutableOnUpdate();
        
        // Owner can delete their own existing gang sheet.
        allow delete: if isExistingOwner(userId);
      }
      
      //-----------------------------------------------------------------------//
      // Subcollection: drafts
      //-----------------------------------------------------------------------//
      match /drafts/{draftId} {
        allow read, write: if isOwner(userId);
      }

      //-----------------------------------------------------------------------//
      // Subcollection: orders (user-specific view)
      //-----------------------------------------------------------------------//

      /**
       * @description Controls access to a user's private view of their orders.
       * @path /users/{userId}/orders/{orderId}
       * @allow The owner ('user123') reading their own order record. (get, list)
       * @deny A different user ('user456') attempting to read an order owned by 'user123'. (get)
       * @principle Enforces strict read-only ownership for a user's personal order history.
       */
      match /orders/{orderId} {
        // Owner can read their own orders and list their collection for their dashboard.
        allow get, list: if isOwner(userId);
        
        // A user can create a copy of their own order in their subcollection.
        allow create: if isOwner(userId) && hasValidUserOrderDataOnCreate(userId);
        
        // Admins can update the user-facing order (e.g. status changes). The user cannot.
        allow update: if isAdmin() && isUserOrderDataImmutableOnUpdate();

        // Deleting user-facing orders is disabled.
        allow delete: if false;
      }
    }
    
    //-------------------------------------------------------------------------//
    // Collection: orders (central collection for admin)
    //-------------------------------------------------------------------------//
    
    /**
     * @description Controls access to the central `orders` collection for fulfillment.
     * @path /orders/{orderId}
     * @allow An admin user reading, listing, or updating any order. (get, list, update)
     * @allow Any authenticated user creating a new order FOR THEMSELVES. (create)
     * @deny Non-admins from listing or updating orders. (list, update)
     */
     match /orders/{orderId} {
        // Admins have full read/update access for fulfillment.
        allow get, list, update: if isAdmin();
        
        // Any signed-in user can create an order, but only for themselves.
        allow create: if isSignedIn() && isCreatingOwnOrder();
        
        // Orders should not be deleted from the central log.
        allow delete: if false;
     }
  }
}
