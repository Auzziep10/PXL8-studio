/**
 * This ruleset enforces a security model based on user ownership and a separate
 * administrative role lookup. It is designed for rapid prototyping, focusing on
 * strong authorization while maintaining flexibility in data schemas.
 *
 * Core Philosophy:
 * By default, all data is private. Access is granted explicitly based on two main
 * principles: a user owns the data within their own document tree, or a user has
 * a global administrative role.
 *
 * Data Structure:
 * - /users/{userId}: Stores private user profile data. Each user can only access
 *   their own document.
 * - /users/{userId}/orders/{orderId}: A subcollection for user-specific orders,
 *   inheriting ownership from the parent user document.
 * - /users/{userId}/drafts/{draftId}: A subcollection for user-specific draft
 *   documents, like in-progress gang sheets.
 * - /orders/{orderId}: A centralized collection of all orders for admin access.
 * - /roles_admin/{userId}: A separate, client-inaccessible collection used as a
 *   lookup table. The existence of a document here grants a user admin privileges
 *   across the database.
 *
 * Key Security Decisions:
 * - User Enumeration Disabled: Non-admin users cannot list the contents of the
 *   top-level /users collection to protect user privacy.
 * - Admin Role Segregation: Admin status is managed in /roles_admin, which is
 *   read-only for all clients. This prevents users from escalating their own
 *   privileges. Rules use `exists()` checks against this collection for efficient
 *   and secure role verification.
 * - Path-Based Ownership: Security for nested data like orders is primarily
 *   determined by the /users/{userId} path, making rules simple and performant.
 * - Signup Enabled: A user can create their own profile document in /users/{userId}
 *   immediately after authentication, which is essential for a signup flow.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the given userId.
     * This is the primary function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the authenticated user has an admin role.
     * This is determined by the existence of a document in the roles_admin collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    

    /**
     * A robust check for update/delete operations, ensuring the user is the
     * owner and the document actually exists before the operation.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates required authorization fields during user document creation.
     * Ensures the document's internal `id` matches the user's auth UID.
     */
    function isNewUserDocumentValid(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * Enforces immutability of critical authorization fields on user document update.
     * Prevents the user from changing their own `id` field.
     */
    function isUserDocumentUpdateValid() {
      return request.resource.data.id == resource.data.id;
    }


    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     * @allow (create) An authenticated user creating their own profile document.
     * @deny  (list) A non-admin user trying to list all user profiles.
     * @deny  (get) A user trying to read another user's profile.
     * @principle Restricts access to a user's own data tree and allows self-creation for signup.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isNewUserDocumentValid(userId);
      allow update: if isExistingOwner(userId) && isUserDocumentUpdateValid();
      allow delete: if isExistingOwner(userId);

      /**
       * @description Stores user-specific order information.
       * @path /users/{userId}/orders/{orderId}
       * @allow (create, get, list, update, delete) A user managing their own orders.
       * @deny  (get) A user trying to read another user's orders.
       * @principle Enforces document ownership via path hierarchy for all operations.
       */
      match /orders/{orderId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      /**
       * @description Stores user-specific draft documents, like gang sheets.
       * @path /users/{userId}/drafts/{draftId}
       * @allow (create, get, list, update, delete) A user managing their own drafts.
       * @deny  (get) A user trying to read another user's drafts.
       * @principle Enforces document ownership via path hierarchy for all draft operations.
       */
      match /drafts/{draftId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    /**
     * @description Centralized collection for all orders, for admin access.
     * @path /orders/{orderId}
     * @allow (read, list, update) An admin can manage all orders.
     * @allow (create) Any authenticated user can create an order.
     * @deny (delete) No one can delete from the central order log.
     */
    match /orders/{orderId} {
        allow read, list, update: if isAdmin();
        allow create: if isSignedIn();
        allow delete: if false; // Prevent accidental deletion of order log
    }


    /**
     * @description A private collection to check for administrative roles.
     * @path /roles_admin/{userId}
     * @allow (create) A user can claim their own admin role (one-time).
     * @deny  (get, list, update, delete) Any user trying to read or modify this collection.
     * @principle Secures role-based access control by making the role data inaccessible from the client-side.
     */
    match /roles_admin/{userId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if false;
    }
  }
}
