
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Match any file within a user-specific folder.
    // The {userId} wildcard captures the user's unique ID from the path.
    match /users/{userId}/{allPaths=**} {
      // Allow read, write, and delete operations only if the requesting user is authenticated
      // and their UID matches the {userId} in the path. This is the core of our
      // user-ownership security model.
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for temporary mobile uploads
    match /upload_sessions/{sessionId}/{allPaths=**} {
      // Allow anyone to write a file here. This is safe because the sessionID
      // is a long, unguessable UID, acting as a temporary secret upload folder.
      // We also add a size limit to prevent abuse.
      allow write: if request.resource.size < 10 * 1024 * 1024;
      
      // Only the session owner can read the file they just uploaded.
      allow read: if request.auth != null && request.auth.uid == sessionId;
    }
  }
}
